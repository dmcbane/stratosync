# Maintainer: Dale McBane <noreply@example.com>
pkgname=stratosync-git
pkgver=0.12.0
pkgrel=1
pkgdesc="Linux cloud sync daemon with on-demand FUSE3 filesystem"
arch=('x86_64' 'aarch64')
url="https://github.com/dmcbane/stratosync"
license=('MIT' 'Apache-2.0')
depends=('fuse3' 'rclone')
makedepends=('rust' 'cargo' 'git')
optdepends=(
    'python-nautilus: Nautilus (GNOME) sync-status emblems and context-menu actions'
    'nemo-python: Nemo (Cinnamon) sync-status emblems and context-menu actions'
    'python-caja: Caja (MATE) sync-status emblems and context-menu actions'
    'libappindicator-gtk3: system tray indicator support'
)
provides=('stratosync')
conflicts=('stratosync')
source=("git+https://github.com/dmcbane/stratosync.git")
sha256sums=('SKIP')

pkgver() {
    cd stratosync
    git describe --long --tags 2>/dev/null | sed 's/^v//;s/-/.r/;s/-/./' || echo "$pkgver"
}

build() {
    cd stratosync
    cargo build --release
}

check() {
    cd stratosync
    cargo test --workspace
}

package() {
    cd stratosync
    install -Dm755 target/release/stratosyncd "$pkgdir/usr/bin/stratosyncd"
    install -Dm755 target/release/stratosync "$pkgdir/usr/bin/stratosync"
    install -Dm755 contrib/file-managers/bin/stratosync-fm-action "$pkgdir/usr/bin/stratosync-fm-action"
    install -Dm644 contrib/systemd/stratosyncd.service "$pkgdir/usr/lib/systemd/user/stratosyncd.service"
    # File manager extensions (Nautilus / Nemo / Caja). The shared helper
    # is duplicated into each FM's extension directory because each
    # loader can only see its own.
    for fm in nautilus nemo caja; do
        install -Dm644 "contrib/file-managers/common/stratosync_fm_common.py" \
            "$pkgdir/usr/share/${fm}-python/extensions/stratosync_fm_common.py"
    done
    install -Dm644 contrib/file-managers/nautilus/stratosync_nautilus.py "$pkgdir/usr/share/nautilus-python/extensions/stratosync_nautilus.py"
    install -Dm644 contrib/file-managers/nemo/stratosync_nemo.py         "$pkgdir/usr/share/nemo-python/extensions/stratosync_nemo.py"
    install -Dm644 contrib/file-managers/caja/stratosync_caja.py         "$pkgdir/usr/share/caja-python/extensions/stratosync_caja.py"
    # Declarative-action file managers (Dolphin / PCManFM). Thunar is
    # manual-merge — uca.xml shipped under share/doc.
    install -Dm644 contrib/file-managers/dolphin/stratosync.desktop      "$pkgdir/usr/share/kio/servicemenus/stratosync.desktop"
    for f in contrib/file-managers/pcmanfm/stratosync-*.desktop; do
        install -Dm644 "$f" "$pkgdir/usr/share/file-manager/actions/$(basename "$f")"
    done
    install -Dm644 contrib/file-managers/thunar/stratosync-uca.xml       "$pkgdir/usr/share/doc/$pkgname/thunar/stratosync-uca.xml"
    install -Dm644 contrib/file-managers/thunar/README.md                "$pkgdir/usr/share/doc/$pkgname/thunar/README.md"
    install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
    install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
}
